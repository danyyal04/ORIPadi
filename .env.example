APP_NAME="PadiGuard AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-cloudrun-url.run.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ─── Google Gemini AI ───────────────────────────────────────
# Obtain your free API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
